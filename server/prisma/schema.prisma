generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RestaurantMemberRole {
  OWNER
  ADMIN
  MANAGER
}

enum AssetKind {
  MODEL_3D
  MODEL_3D_LOD0
  PREVIEW_3D
  THUMBNAIL
  POSTER
  CROSS_SELL_IMAGE
}

enum AssetStatus {
  PENDING
  READY
  FAILED
}

enum CurrencyCode {
  USD
  INR
  EUR
  GBP
  AED
}

enum DietaryType {
  VEG
  NON_VEG
  BOTH
}

model User {
  id               String             @id @default(uuid())
  email            String             @unique
  passwordHash     String
  name             String?
  mobile           String?
  companyName      String?
  location         String?
  profilePicUrl    String?
  welcomeEmailSent Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  memberships      RestaurantMember[]
  restaurantsOwned Restaurant[]       @relation("RestaurantOwner")
}

model PendingManagerOtp {
  id            String   @id @default(uuid())
  restaurantId  String   @unique
  email         String
  passwordHash  String
  name          String?
  mobile        String?
  profilePicUrl String?
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([restaurantId])
  @@index([expiresAt])
}

model Restaurant {
  id                          String             @id @default(uuid())
  name                        String
  publicId                    String             @unique
  ownerId                     String
  address                     String?
  coverImageUrl               String?
  logoUrl                     String?
  isActive                    Boolean            @default(true)
  isPublished                 Boolean            @default(false)
  managerPortalTheme          String             @default("DEFAULT")
  publicMenuSnapshot          Json?
  publicMenuSnapshotUpdatedAt DateTime?
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt

  owner      User       @relation("RestaurantOwner", fields: [ownerId], references: [id])
  members    RestaurantMember[]
  menus      MainMenu[]
  categories Menu[]
  dishes     Dish[]
  assets     Asset[]

  @@index([ownerId])
  @@index([publicId])
  @@index([isActive])
  @@index([isPublished])
}

model MainMenu {
  id           String   @id @default(uuid())
  name         String
  restaurantId String
  isPublished  Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  categories Menu[]

  @@index([restaurantId])
  @@index([restaurantId, isPublished, sortOrder])
}

model RestaurantMember {
  id           String               @id @default(uuid())
  userId       String
  restaurantId String
  role         RestaurantMemberRole
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([userId, restaurantId])
  @@index([userId])
  @@index([restaurantId, role])
}

model Menu {
  id           String   @id @default(uuid())
  name         String
  restaurantId String
  mainMenuId   String
  isPublished  Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  mainMenu   MainMenu   @relation(fields: [mainMenuId], references: [id])
  dishes     Dish[]

  @@index([restaurantId])
  @@index([mainMenuId])
  @@index([mainMenuId, isPublished, sortOrder])
}

model Dish {
  id           String   @id @default(uuid())
  name         String
  price        Int
  currency     CurrencyCode @default(USD)
  description  String?
  badgeLabel   String?
  servingSize  Int      @default(2)
  detailsPanelEnabled Boolean @default(true)
  crossSellItems Json   @default("[]")
  restaurantId String
  menuId       String
  dietaryType  DietaryType?
  isPublished  Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  menu       Menu       @relation(fields: [menuId], references: [id])
  assets     Asset[]

  @@index([restaurantId])
  @@index([menuId])
  @@index([restaurantId, isPublished, sortOrder])
}

model Asset {
  id           String      @id @default(uuid())
  dishId       String
  restaurantId String
  kind         AssetKind
  status       AssetStatus @default(PENDING)
  storageKey   String
  url          String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  dish       Dish       @relation(fields: [dishId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([dishId])
  @@index([dishId, kind])
  @@index([restaurantId, kind])
  @@index([status])
}
